<?xml version="1.0" encoding="utf-8"?>
<!-- Create Character Screen -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="20dp">

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Create Character"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#000000"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Name input -->
    <EditText
        android:id="@+id/nameInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:hint="Enter name"
        android:textColor="#000000"
        android:textColorHint="#666666"/>

    <!-- Class selection -->
    <Spinner
        android:id="@+id/classSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:layout_marginTop="12dp"/>

    <!-- Class stats title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Class Stats"
        android:textColor="#000000"
        android:textStyle="bold"
        android:layout_marginTop="20dp"/>

    <!-- Class stats -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pilot      Skill 5   Res 4   HP 20&#10;Engineer   Skill 6   Res 3   HP 19&#10;Medic      Skill 7   Res 2   HP 18&#10;Scientist  Skill 8   Res 1   HP 17&#10;Soldier    Skill 9   Res 0   HP 16"
        android:textColor="#000000"
        android:fontFamily="monospace"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="8dp"/>

    <!-- Create button -->
    <Button
        android:id="@+id/createButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:text="Create"
        android:textColor="#000000"
        android:layout_marginTop="20dp"/>

    <!-- Go to Quarters -->
    <Button
        android:id="@+id/goToQuarters"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="48dp"
        android:text="Go To Quarters"
        android:textColor="#000000"
        android:layout_marginTop="10dp"/>

</LinearLayout>